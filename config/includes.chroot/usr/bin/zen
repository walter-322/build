PACKAGES["rust"]="dev"
PACKAGES["docker"]="dev"
PACKAGES["vscode"]="dev"

# ═══════════════════════════════════════════════════════════════════════════════
# PACK INSTALL FUNCTIONS (Debian repo bundles)
# ═══════════════════════════════════════════════════════════════════════════════

install_gaming-pack() {
    print_info "Installing Gaming Pack..."
    print_info "Packages: lutris, wine, winetricks, gamemode, mangohud, vulkan-tools, mesa-vulkan-drivers"
    echo ""

    sudo dpkg --add-architecture i386
    sudo apt update
    sudo apt install -y \
        lutris \
        wine \
        winetricks \
        gamemode \
        mangohud \
        vulkan-tools \
        mesa-vulkan-drivers \
        mesa-vulkan-drivers:i386 \
        libgl1-mesa-dri:i386 \
        libglx-mesa0:i386
}

remove_gaming-pack() {
    print_info "Removing Gaming Pack..."
    sudo apt remove -y lutris wine winetricks gamemode mangohud vulkan-tools || true
    sudo apt autoremove -y
}

install_editor-pack() {
    print_info "Installing Editor Pack..."
    print_info "Packages: gimp, krita, inkscape, pinta"
    echo ""

    sudo apt update
    sudo apt install -y gimp krita inkscape pinta
}

remove_editor-pack() {
    print_info "Removing Editor Pack..."
    sudo apt remove -y gimp krita inkscape pinta || true
    sudo apt autoremove -y
}

install_producer-pack() {
    print_info "Installing Producer Pack..."
    print_info "Packages: ardour, audacity, lmms, musescore, hydrogen, rosegarden"
