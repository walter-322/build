#!/bin/bash

# Developed by root0emir
# zenclora.org

# ╔═══════════════════════════════════════════════════════════════════════════════╗
# ║                            ZEN PACKAGE MANAGER                                ║
# ║                      Zenclora's Unified Package Manager                       ║
# ║                                                                               ║
# ║  Usage: zen <command> [options]                                               ║
# ║                                                                               ║
# ║  Commands:                                                                    ║
# ║    install <package>    Install a package                                     ║
# ║    remove <package>     Remove a package                                      ║
# ║    update               Update system and all packages                        ║
# ║    system <action>      System utilities (dns, zram, net, cleanup)            ║
# ║    list                 List available packages                               ║
# ║    help                 Show this help message                                ║
# ╚═══════════════════════════════════════════════════════════════════════════════╝

set -e
    
# ═══════════════════════════════════════════════════════════════════════════════
BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

ZEN_VERSION="1.0"

# ═══════════════════════════════════════════════════════════════════════════════
# HELPER FUNCTIONS
# ═══════════════════════════════════════════════════════════════════════════════

print_banner() {
    echo -e "${PURPLE}"
    echo "  ╔═══════════════════════════════════════════╗"
    echo "  ║     ███████╗███████╗███╗   ██╗            ║"
    echo "  ║     ╚══███╔╝██╔════╝████╗  ██║            ║"
    echo "  ║       ███╔╝ █████╗  ██╔██╗ ██║            ║"
    echo "  ║      ███╔╝  ██╔══╝  ██║╚██╗██║            ║"
    echo "  ║     ███████╗███████╗██║ ╚████║            ║"
    echo "  ║     ╚══════╝╚══════╝╚═╝  ╚═══╝            ║"
    echo "  ║                                           ║"
    echo "  ║   Zenclora Package Manager v${ZEN_VERSION}           ║"
    echo "  ╚═══════════════════════════════════════════╝"
    echo -e "${NC}"
}

print_success() {
    echo -e "${GREEN}[+] $1${NC}"
}

print_error() {
    echo -e "${RED}[-] $1${NC}"
}

print_info() {
    echo -e "${CYAN}[*] $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}[!] $1${NC}"
}

require_root() {
    if [[ $EUID -ne 0 ]]; then
        print_error "This command requires root privileges. Please run with sudo."
        exit 1
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# PACKAGE DEFINITIONS
# ═══════════════════════════════════════════════════════════════════════════════

# Available packages (name -> category)
declare -A PACKAGES

# Packs (Debian repo bundles)
PACKAGES["gaming-pack"]="pack"
PACKAGES["editor-pack"]="pack"
PACKAGES["producer-pack"]="pack"
PACKAGES["office-pack"]="pack"
PACKAGES["dev-pack"]="pack"

# External Apps (need repo setup)
# External Apps (need repo setup)
PACKAGES["steam"]="gaming"
PACKAGES["brave"]="browser"
PACKAGES["chrome"]="browser"
PACKAGES["mullvad-vpn"]="privacy"
PACKAGES["mullvad-browser"]="privacy"
PACKAGES["librewolf"]="privacy"
PACKAGES["spotify"]="media"
PACKAGES["signal"]="productivity"

# AI Tools
PACKAGES["cursor"]="ai"
PACKAGES["windsurf"]="ai"
PACKAGES["antigravity"]="ai"
PACKAGES["ollama"]="ai"

# System/Dev Tools
PACKAGES["flatpak"]="system"
PACKAGES["snap"]="system"
PACKAGES["pacstall"]="system"
PACKAGES["liquorix"]="kernel"
