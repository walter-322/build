    sudo apt autoremove -y
}

# ═══════════════════════════════════════════════════════════════════════════════
# EXTERNAL APP INSTALL FUNCTIONS (need repo setup)
# ═══════════════════════════════════════════════════════════════════════════════

install_steam() {
    print_info "Adding i386 architecture..."
    sudo dpkg --add-architecture i386

    print_info "Downloading and adding Steam GPG key..."
    curl -s http://repo.steampowered.com/steam/archive/stable/steam.gpg | sudo tee /usr/share/keyrings/steam.gpg > /dev/null

    print_info "Adding Steam repository..."
    sudo tee /etc/apt/sources.list.d/steam-stable.list <<'EOF'
deb [arch=amd64,i386 signed-by=/usr/share/keyrings/steam.gpg] https://repo.steampowered.com/steam/ stable steam
deb-src [arch=amd64,i386 signed-by=/usr/share/keyrings/steam.gpg] https://repo.steampowered.com/steam/ stable steam
EOF

    print_info "Updating package lists..."
    sudo apt update

    print_info "Installing Steam dependencies..."
    sudo apt install -y mesa-vulkan-drivers libglx-mesa0:i386 mesa-vulkan-drivers:i386 libgl1-mesa-dri:i386

    print_info "Installing Steam Launcher..."
    sudo apt install -y steam-launcher
}

remove_steam() {
    print_info "Removing Steam..."
    sudo apt remove -y steam-launcher || true
    sudo rm -f /etc/apt/sources.list.d/steam-stable.list
    sudo rm -f /usr/share/keyrings/steam.gpg
    sudo apt update
}

# Lutris is now in gaming-pack, standalone function removed

install_brave() {
    print_info "Downloading and adding Brave GPG key..."
    sudo curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg

    print_info "Adding Brave repository..."
    echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg] https://brave-browser-apt-release.s3.brave.com/ stable main" | sudo tee /etc/apt/sources.list.d/brave-browser-release.list

    print_info "Installing Brave Browser..."
    sudo apt update
    sudo apt install -y brave-browser
    
    # Remove duplicate desktop entry
    sudo rm -f /usr/share/applications/com.brave.Browser.desktop
}

remove_brave() {
    print_info "Removing Brave Browser..."
    sudo apt remove -y brave-browser || true
    sudo rm -f /etc/apt/sources.list.d/brave-browser-release.list
    sudo rm -f /usr/share/keyrings/brave-browser-archive-keyring.gpg
    sudo apt update
}

install_chrome() {
    print_info "Adding Google Chrome repository..."
    wget -q -O- https://dl.google.com/linux/linux_signing_key.pub | sudo gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg
    echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" | sudo tee /etc/apt/sources.list.d/google-chrome.list

    print_info "Installing Google Chrome..."
    sudo apt update
    sudo apt install -y google-chrome-stable
}

remove_chrome() {
    print_info "Removing Google Chrome..."
    sudo apt remove -y google-chrome-stable || true
    sudo rm -f /etc/apt/sources.list.d/google-chrome.list
    sudo rm -f /usr/share/keyrings/google-chrome.gpg
    sudo apt update
}

install_cursor() {
    print_info "Downloading and adding Cursor GPG key..."
    curl -fsSL https://downloads.cursor.com/keys/anysphere.asc | gpg --dearmor | sudo tee /etc/apt/keyrings/cursor.gpg > /dev/null

    print_info "Adding Cursor repository..."
    echo "deb [arch=amd64,arm64 signed-by=/etc/apt/keyrings/cursor.gpg] https://downloads.cursor.com/aptrepo stable main" | sudo tee /etc/apt/sources.list.d/cursor.list > /dev/null

    print_info "Installing Cursor..."
    sudo apt update
    sudo apt install -y cursor
}

remove_cursor() {
    print_info "Removing Cursor..."
    sudo apt remove -y cursor || true
    sudo rm -f /etc/apt/sources.list.d/cursor.list
    sudo rm -f /etc/apt/keyrings/cursor.gpg
    sudo apt update
}

install_windsurf() {
    print_info "Installing dependencies..."
    sudo apt-get install -y wget gpg apt-transport-https

    print_info "Downloading and adding Windsurf GPG key..."
    wget -qO- "https://windsurf-stable.codeiumdata.com/wVxQEIWkwPUEAGf3/windsurf.gpg" | gpg --dearmor > /tmp/windsurf-stable.gpg
    sudo install -D -o root -g root -m 644 /tmp/windsurf-stable.gpg /etc/apt/keyrings/windsurf-stable.gpg
    rm -f /tmp/windsurf-stable.gpg

    print_info "Adding Windsurf repository..."
    echo "deb [arch=amd64 signed-by=/etc/apt/keyrings/windsurf-stable.gpg] https://windsurf-stable.codeiumdata.com/wVxQEIWkwPUEAGf3/apt stable main" | sudo tee /etc/apt/sources.list.d/windsurf.list > /dev/null

    print_info "Installing Windsurf..."
    sudo apt update
    sudo apt install -y windsurf
}

remove_windsurf() {
    print_info "Removing Windsurf..."
    sudo apt remove -y windsurf || true
    sudo rm -f /etc/apt/sources.list.d/windsurf.list
    sudo rm -f /etc/apt/keyrings/windsurf-stable.gpg
    sudo apt update
}

install_antigravity() {
    print_info "Downloading and adding Antigravity GPG key..."
    sudo mkdir -p /etc/apt/keyrings
    curl -fsSL https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg | \
      sudo gpg --dearmor --yes -o /etc/apt/keyrings/antigravity-repo-key.gpg

    print_info "Adding Antigravity repository..."
    echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" | \
      sudo tee /etc/apt/sources.list.d/antigravity.list > /dev/null

    print_info "Installing Antigravity..."
    sudo apt update
    sudo apt install -y antigravity
}

remove_antigravity() {
    print_info "Removing Antigravity..."
    sudo apt remove -y antigravity || true
    sudo rm -f /etc/apt/sources.list.d/antigravity.list
    sudo rm -f /etc/apt/keyrings/antigravity-repo-key.gpg
    sudo apt update
}

